# ============================================
# Sentinella Italia — Configurazione Produzione
# ============================================

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://postgres:CHANGE_ME@db:5432/sentinella
DB_PASSWORD=CHANGE_ME

# CORS — origini consentite (separate da virgola)
CORS_ORIGINS=https://sentinella.example.com

# Autenticazione API (generare con: python -c "import secrets; print(secrets.token_urlsafe(32))")
API_KEY=CHANGE_ME

# Rate limiting (richieste per minuto per IP, 0 = disabilitato)
RATE_LIMIT_PER_MINUTE=60

# Debug (DEVE essere false in produzione)
DEBUG=false

# Scheduler
SCHEDULER_ENABLED=true
SCHEDULER_INTERVAL_MINUTES=30

# ACLED (registrazione gratuita su https://acleddata.com)
ACLED_API_KEY=
ACLED_EMAIL=

# OpenSky Network (opzionale, per dati ADS-B)
OPENSKY_USERNAME=
OPENSKY_PASSWORD=

# Anthropic (opzionale, per narrativa AI)
ANTHROPIC_API_KEY=

# Redis
REDIS_URL=redis://redis:6379

{
  "$schema": "https://raw.githubusercontent.com/nicegui-org/nicegui-ui/main/schema/tauri-conf-v2.json",
  "productName": "Boomer Assistant",
  "version": "0.1.0",
  "identifier": "com.italysecurityboard.boomer-assistant",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Assistente",
        "width": 480,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "minWidth": 400,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "models/*"
    ],
    "macOS": {
      "entitlements": null,
      "signingIdentity": null,
      "providerShortName": null,
      "minimumSystemVersion": "10.15"
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}

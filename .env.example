# Database
DB_PASSWORD=sentinella_dev

# CORS — origini consentite (separate da virgola)
# Default: localhost per sviluppo
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:3001

# Autenticazione API (vuoto = auth disabilitata, consigliato per dev)
API_KEY=

# Rate limiting (richieste per minuto per IP, 0 = disabilitato)
RATE_LIMIT_PER_MINUTE=0

# ACLED (registrazione gratuita su https://acleddata.com)
ACLED_API_KEY=
ACLED_EMAIL=

# Debug
DEBUG=true

# Scheduler
SCHEDULER_ENABLED=true

# Frequenza aggiornamento score (minuti)
# Valori consigliati: 15, 30, 60, 120, 240
# Fonti lente (Google Trends, ACLED) usano cache interna indipendente
SCHEDULER_INTERVAL_MINUTES=30

# OpenSky (opzionale, per dati ADS-B)
OPENSKY_USERNAME=
OPENSKY_PASSWORD=
